    "body": {
      "blocks": [
        {
          "id": "body_intro",
          "type": "text",
          "label": "Inleiding",
          "content": {
            "type": "doc",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "De HR-afdeling verzoekt u een gebruikersaccount aan te maken voor onderstaande nieuwe medewerker. De onboarding is afgerond en goedgekeurd. De medewerker dient toegang te krijgen conform de onderstaande specificaties."
                  }
                ]
              }
            ]
          }
        },
        {
