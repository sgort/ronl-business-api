        },
        {
          "id": "body_access_details",
          "type": "text",
          "label": "Rollen en toegangsniveau",
          "content": {
            "type": "doc",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Toegangsniveau: ",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": "{{accessLevel}}"
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Realm rollen (Keycloak): ",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": "{{assignedRoles}}"
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Taakgroepen (Operaton): ",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ]
                  },
                  {
                    "type": "text",
                    "text": "{{candidateGroups}}"
                  }
                ]
              }
            ]
          }
        },
        {
          "id": "body_instructions_heading",
          "type": "text",
          "label": "Instructies",
          "content": {
            "type": "doc",
            "content": [
              {
                "type": "heading",
                "attrs": {
                  "level": 2
                },
                "content": [
                  {
                    "type": "text",
                    "text": "Handelingsinstructies"
                  }
                ]
              }
            ]
          }
        },
        {
          "id": "body_instructions",
          "type": "text",
          "label": "Stappen voor IT",
          "content": {
            "type": "doc",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "1. Maak een gebruikersaccount aan in Keycloak realm "
                  },
                  {
                    "type": "text",
                    "text": "ronl"
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "   — Gebruikersnaam: conform naamgevingsconventie {{firstName}}.{{lastName}}-{{municipality}}"
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "   — User attribute "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ],
                    "text": "municipality"
                  },
                  {
                    "type": "text",
                    "text": " instellen op: {{municipality}}"
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "   — User attribute "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ],
                    "text": "employee_id"
                  },
                  {
                    "type": "text",
                    "text": " instellen op: {{employeeId}}"
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "   — User attribute "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ],
                    "text": "assurance_level"
                  },
                  {
                    "type": "text",
                    "text": " instellen op: hoog"
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "   — User attribute "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ],
                    "text": "organisation_type"
                  },
                  {
                    "type": "text",
                    "text": " instellen op: {{organisationType}}"
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "2. Ken de volgende realm rollen toe: "
                  },
                  {
                    "type": "text",
                    "text": "{{assignedRoles}}"
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "3. Stel een tijdelijk wachtwoord in en zet "
                  },
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "italic"
                      }
                    ],
                    "text": "Temporary"
                  },
                  {
                    "type": "text",
                    "text": " op aan zodat de medewerker dit bij eerste inlog wijzigt."
                  }
                ]
              },
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "marks": [
                      {
                        "type": "bold"
                      }
                    ],
                    "text": "4. Bevestig aanmaak aan HR via hr@flevoland.nl met vermelding van medewerker-ID {{employeeId}}."
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "closing": {
