          "content": {
            "type": "doc",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "Wij verzoeken u het account uiterlijk één werkdag vóór de startdatum ({{startDate}}) aan te maken zodat de medewerker op de eerste werkdag direct toegang heeft."
                  }
                ]
              }
            ]
